# Copy this file to .env and fill in real values. Never commit .env (already in .gitignore).
# This site is currently static HTML/CSS/JS — no server reads these yet.
# Add them here now so they're ready the moment a backend/serverless function is wired in.

# Tally.so form (contact.html) - optional, only needed if you add a webhook receiver
TALLY_WEBHOOK_SECRET=

# Stripe (only needed if you move from Payment Links to a custom checkout session)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Maps embed (contact.html) - optional, restrict the key to this domain in Google Cloud Console
GOOGLE_MAPS_API_KEY=
